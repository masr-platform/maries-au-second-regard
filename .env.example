# ══════════════════════════════════════════════
# MARIÉS AU SECOND REGARD — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ══════════════════════════════════════════════

# ─── Application ───────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generer_avec_openssl_rand_base64_32

# ─── Base de données (Supabase) ────────────
DATABASE_URL="postgresql://postgres:[MOT_DE_PASSE]@db.[PROJET_ID].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[MOT_DE_PASSE]@db.[PROJET_ID].supabase.co:5432/postgres"

# ─── Supabase ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJET_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role

# ─── OpenAI (IA de matching) ───────────────
OPENAI_API_KEY=sk-...

# ─── Stripe ────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Plans Stripe (créer dans le dashboard Stripe)
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PREMIUM=price_...

# ─── Redis (Upstash) ───────────────────────
REDIS_URL=rediss://...
REDIS_TOKEN=...

# ─── Email (Resend ou SendGrid) ────────────
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=re_...
EMAIL_FROM=noreply@mariesausecondregard.fr

# ─── Cloudinary (photos) ───────────────────
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ─── Daily.co (visioconférence) ────────────
DAILY_API_KEY=...
DAILY_DOMAIN=votre-domaine.daily.co

# ─── Twilio (SMS) ──────────────────────────
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+33...

# ─── Admin ─────────────────────────────────
ADMIN_EMAIL=admin@mariesausecondregard.fr
